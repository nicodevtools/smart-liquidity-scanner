//@version=5
// 🔍 Smart Liquidity Scanner LITE — Nico (Free Version)
// This is the FREE version. Get the PRO version with alerts, volume filter,
// and advanced features at the link below.
indicator("Smart Liquidity Scanner [LITE]", overlay=true)

// ═══════════════════════════════════════════
// BASIC SETTINGS (PRO has full configuration)
// ═══════════════════════════════════════════
lookback = input.int(50, "Lookback Period", minval=10)

// ── Swing Highs & Lows ──
swingHigh = ta.highest(high, lookback)
swingLow = ta.lowest(low, lookback)

// ── Fair Value Gap ──
bullishFVG = low[2] > high
bearishFVG = high[2] < low

// ── Order Blocks ──
bullishOB = close > open and close[1] < open[1] and high > high[1] and low < low[1]
bearishOB = close < open and close[1] > open[1] and high > high[1] and low < low[1]

// ── Plots ──
// Dynamic S/R
resistance = ta.pivothigh(high, 10, 10)
support = ta.pivotlow(low, 10, 10)
plot(resistance, "Resistance", color=color.new(color.red, 40), linewidth=2, style=plot.style_circles)
plot(support, "Support", color=color.new(color.green, 40), linewidth=2, style=plot.style_circles)

// FVG Background
bgcolor(bullishFVG ? color.new(color.green, 90) : na, title="Bullish FVG")
bgcolor(bearishFVG ? color.new(color.red, 90) : na, title="Bearish FVG")

// Order Block Markers
plotshape(bullishOB ? low : na, "Bullish OB", shape.triangleup, location.belowbar, 
  color=color.new(color.green, 50), size=size.small)
plotshape(bearishOB ? high : na, "Bearish OB", shape.triangledown, location.abovebar, 
  color=color.new(color.red, 50), size=size.small)

// ── Info Label ──
var label infoLabel = na
if barstate.islast
    label.delete(infoLabel)
    infoLabel := label.new(
      bar_index + 10, close,
      "🔍 LITE Version — by Nico\n✨ Get PRO: alerts • volume filter • multi-TF\n📩 DM for access • $5 min USDT/POL\n🔗 0xD404...fc18e",
      color=color.new(color.black, 80),
      textcolor=color.white,
      style=label.style_label_left,
      size=size.small,
      textalign=text.align_left
    )

